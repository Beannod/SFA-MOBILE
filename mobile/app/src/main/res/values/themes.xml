<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SfaMobile" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <!-- Primary-dark status bar so notification bar icons are visible -->
        <item name="android:statusBarColor">#3A0CA3</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <!-- Light navigation bar icons (dark icons on white bg) -->
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
