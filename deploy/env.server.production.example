# SFA API — Production Environment Variables
# Copy this file to a secure location and fill in real values.
# NEVER commit the filled-in file to source control.
#
# On Render: set each variable in Dashboard → Service → Environment.
# On other hosts: export these before running `dotnet out/SfaApi.dll`.

# ── ASP.NET Core ──────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production

# ── Database (AWS RDS SQL Server) ─────────────────────────────────────────────
# Format: Server=<RDS-ENDPOINT>,1433;Database=ReportApp;User Id=<USER>;******;TrustServerCertificate=True;
ConnectionStrings__DefaultConnection=Server=<RDS-ENDPOINT>,1433;Database=ReportApp;User Id=sfa_user;******;TrustServerCertificate=True;

# ── JWT (Phase 4 — leave empty until JWT auth is implemented) ─────────────────
Jwt__Key=<RANDOM-256-BIT-SECRET>
Jwt__Issuer=https://api.yourdomain.com
Jwt__Audience=sfa-mobile

# ── Port (set automatically by Render; override only if self-hosting) ─────────
# PORT=5000
