# Example environment variables for local development and production
# Do NOT commit secret values. Copy to .env.local (gitignored) and fill secrets.

# Database
ConnectionStrings__DefaultConnection=Server=(localdb)\\mssqllocaldb;Database=sfa_dev;Trusted_Connection=True;MultipleActiveResultSets=true

# ASP.NET environment
ASPNETCORE_ENVIRONMENT=Development

# Port (optional) - hosting may override
PORT=5000

# JWT (replace in production)
Jwt__Key=replace-with-strong-secret
Jwt__Issuer=your-app-issuer
Jwt__Audience=your-app-audience

# Optional: any other service keys, e.g., storage, mail
# STORAGE__SOMEKEY=...
